[Unit]
Description=EECampEdu Student-PC Camera / Control App (localhost:8770)
# Docs: apps/local_camera_app/README.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@REPO@
ExecStart=@PYTHON@ apps/local_camera_app/preview_app.py
Restart=on-failure
RestartSec=3
# Logs go to the journal: journalctl --user -u eecamp-camera-app -f

[Install]
WantedBy=default.target
