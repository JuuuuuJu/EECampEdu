# EECampEdu training portal service environment.
# Copy to deploy/eecamp-portal.env (git-ignored) and fill in real values.
#   cp deploy/eecamp-portal.env.example deploy/eecamp-portal.env
#   chmod 600 deploy/eecamp-portal.env
# The service reads this file via systemd EnvironmentFile (optional).

# Flask session secret — set to a long random string for real class use.
EECAMP_PORTAL_SECRET=change-this-session-secret

# Per-team passwords as JSON. If unset, the dev fallback eecamp01..eecamp10 is used.
# EECAMP_TEAM_PASSWORDS={"team01":"...","team02":"..."}
