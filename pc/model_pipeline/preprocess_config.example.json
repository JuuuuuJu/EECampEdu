{
  "version": 1,
  "camera_frame": {
    "preferred_format": "grayscale",
    "test_frame_width": 160,
    "test_frame_height": 160
  },
  "esp_preprocess": {
    "crop_on_esp": true,
    "crop_method": "threshold_dark_foreground",
    "resize_width": 96,
    "resize_height": 96,
    "normalize": "pixel / 255.0",
    "quantize": "round(normalized / input_scale) + input_zero_point"
  },
  "model_input": {
    "shape": [1, 96, 96, 1],
    "dtype": "int8"
  },
  "model_output": {
    "shape": [1, 5],
    "dtype": "int8",
    "class_order": ["up", "down", "right", "left", "null"]
  }
}
